tbx <- open(TabixFile("~/Desktop/test.vcf.gz", yieldSize=10000))
# Initialize variables
batch_coordinates <- c()
while(length(res <- scanTabix(tbx)[[1]])) {
# Extract chromosome and position from the first and last variant
first_variant_info <- strsplit(res[1], "\t")[[1]]
last_variant_info <- strsplit(res[length(res)], "\t")[[1]]
first_chrom <- first_variant_info[1]
last_chrom <- last_variant_info[1]
# Check if the batch spans more than one chromosome
if (first_chrom != last_chrom) {
# Find the last variant of the current chromosome
last_of_chrom_index <- max(which(sapply(res, function(x) strsplit(x, "\t")[[1]][1]) == first_chrom))
# Process the first part of the batch (up to the end of the current chromosome)
genomic_region_first_part <- paste0(first_chrom, ":", first_variant_info[2], "-", strsplit(res[last_of_chrom_index], "\t")[[1]][2])
print(genomic_region_first_part)
# Start the next batch from the beginning of the next chromosome
# (This is the first variant of the next chromosome in the current batch)
next_chrom_first_variant_info <- strsplit(res[last_of_chrom_index + 1], "\t")[[1]]
next_chrom_first_coord <- paste0(next_chrom_first_variant_info[1], ":", next_chrom_first_variant_info[2])
# Resetting the reading process to start at the next chromosome
tbx <- open(TabixFile("~/Desktop/sim11.vcf.gz", yieldSize=10000))
pushTabix(tbx, next_chrom_first_coord)
next
}
# Construct and print the genomic region for single-chromosome batch
batch_coordinates <- c(batch_coordinates, paste0(first_chrom, ":", first_variant_info[2], "-", last_variant_info[2]))
print(batch_coordinates)
}
tbx <- open(TabixFile("~/Desktop/test.vcf.gz", yieldSize=10000))
# Initialize variables
batch_coordinates <- c()
while(length(res <- scanTabix(tbx)[[1]])) {
# Extract chromosome and position from the first and last variant
first_variant_info <- strsplit(res[1], "\t")[[1]]
last_variant_info <- strsplit(res[length(res)], "\t")[[1]]
first_chrom <- first_variant_info[1]
last_chrom <- last_variant_info[1]
# Check if the batch spans more than one chromosome
if (first_chrom != last_chrom) {
# Find the last variant of the current chromosome
last_of_chrom_index <- max(which(sapply(res, function(x) strsplit(x, "\t")[[1]][1]) == first_chrom))
# Process the first part of the batch (up to the end of the current chromosome)
genomic_region_first_part <- paste0(first_chrom, ":", first_variant_info[2], "-", strsplit(res[last_of_chrom_index], "\t")[[1]][2])
batch_coordinates <- c(batch_coordinates, genomic_region_first_part)
# Start the next batch from the beginning of the next chromosome
# (This is the first variant of the next chromosome in the current batch)
next_chrom_first_variant_info <- strsplit(res[last_of_chrom_index + 1], "\t")[[1]]
genomic_region_second_part <- paste0(last_chrom, ":", next_chrom_first_variant_info[2], "-", last_variant_info[2])
batch_coordinates <- c(batch_coordinates, genomic_region_second_part)
next
}
# Construct and print the genomic region for single-chromosome batch
batch_coordinates <- c(batch_coordinates, paste0(first_chrom, ":", first_variant_info[2], "-", last_variant_info[2]))
}
# Close the Tabix file
close(tbx)
batch_coordinates
