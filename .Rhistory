next
}
# Construct and print the genomic region for single-chromosome batch
batch_coordinates <- c(batch_coordinates, paste0(first_chrom, ":", first_variant_info[2], "-", last_variant_info[2]))
}
# Close the Tabix file
close(tbx)
batch_coordinates
