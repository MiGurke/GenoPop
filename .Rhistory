N_hom_p2_a1 <- 5
N_het_p1 <- 0
N_het_p2 <- 4
# Number of individuals
n_p1 <- (N_hom_p1_a0 + 0.5 * N_het_p1) + (N_hom_p1_a1 + 0.5 * N_het_p1)
n_p2 <- (N_hom_p2_a0 + 0.5 * N_het_p2) + (N_hom_p2_a1 + 0.5 * N_het_p2)
# Allele counts
p1_a0 <- N_het_p1 + 2 * N_hom_p1_a0
p1_a1 <- N_het_p1 + 2 * N_hom_p1_a1
p2_a0 <- N_het_p2 + 2 * N_hom_p2_a0
p2_a1 <- N_het_p2 + 2 * N_hom_p2_a1
# Overall number of individuals
nbar <- n_p1 + n_p2
# Counts of each allele in the two populations together
pbar_a0 <- p1_a0 + p2_a0
pbar_a1 <- p1_a1 + p2_a1
# Count of heterozygote individuals in both populations
hbar <- N_het_p1 + N_het_p2
# Allele frequencies (dividing by the number of chromosomes (diploid: n * 2))
p1_a0 <- p1_a0 / (n_p1 * 2)
p1_a1 <- p1_a1 / (n_p1 * 2)
p2_a0 <- p2_a0 / (n_p2 * 2)
p2_a1 <- p2_a1 / (n_p2 * 2)
# Sum of squares of the number of individuals
sum_nsqr <- n_p1^2 + n_p2^2
# Total sum of individuals across populations
n_sum <- n_p1 + n_p2
# Average number of individuals per populations (hä?)
nbar <- n_sum / N_pops
# Finalizing average allele frequencies calculation
pbar_a0 <- pbar_a0 / (n_sum * 2) # times 2 cause diploidy
pbar_a1 <- pbar_a1 / (n_sum * 2)
# Finalizing the average heterozygosity calculation
hbar <- hbar / n_sum
# Squared Deviations of Allele Frequencies
ssqr_a0 <- ((n_p1 * (p1_a0 - pbar_a0)^2) + (n_p2 * (p2_a0 - pbar_a0)^2)) / ((N_pops - 1) * nbar)
ssqr_a1 <- ((n_p1 * (p1_a1 - pbar_a1)^2) + (n_p2 * (p2_a1 - pbar_a1)^2)) / ((N_pops - 1) * nbar)
# Effective Sample Size per Population
nc <- (n_sum - (sum_nsqr / n_sum)) / (N_pops - 1)
## Components a, b, and c
# Component a
a_a0 <- (ssqr_a0 - (pbar_a0 * (1 - pbar_a0) - (((N_pops - 1) * ssqr_a0) / N_pops) - (hbar / 4)) / (nbar - 1)) * (nbar / nc))
## Components a, b, and c
# Component a
a_a0 <- ssqr_a0 - (pbar_a0 * (1 - pbar_a0) - (((N_pops - 1) * ssqr_a0) / N_pops) - (hbar / 4)) / (nbar - 1)) * nbar / nc
## Components a, b, and c
# Component a
a_a0 <- (ssqr_a0 - (pbar_a0 * (1 - pbar_a0) - (((N_pops - 1) * ssqr_a0) / N_pops) - (hbar / 4)) / (nbar - 1)) * nbar / nc
a_a1 <- (ssqr_a1 - (pbar_a1 * (1 - pbar_a1) - (((N_pops - 1) * ssqr_a1) / N_pops) - (hbar / 4)) / (nbar - 1)) * nbar / nc
# Component b
b_a0 <- (pbar_a0 * (1 - pbar_a0) - (ssqr_a0 * (N_pops - 1) / N_pops) - hbar * (((2 * nbar) - 1) / (4 * nbar))) * nbar / (nbar - 1)
# Fst value for each allele?!
snp_Fst_a0 <- a_a0 / (a_a0 + b_a0 + c_a0)
snp_Fst_a1 <- a_a1 / (a_a1 + b_a1 + c_a1)
