# 1. Allele freqs
n1j <- 0
n2j <- 14
n1 <- 12
n2 <- 20
p1j <- n1j/n1
p2j <- n2j/n2
# 2. Heterozygosity
Nhet1j <- 0
Nhet2j <- 4
h1j <- Nhet1j / (n1 / 2)
h2j <- Nhet2j / (n2 / 2)
hbarj <- (h1j * (n1 / 2) + h2j * (n2 / 2)) / ((n1 / 2) + (n2 / 2 ))
# 3. Average allele freqs across populations
pbarj <- (p1j * n1 + p2j * n2) / (n1 + n2)
# 4. Sample size corrections
nbar <- (n1 + n2) / 2
nc  <- n1 + n2 - (n1^2 + n2^2) / (n1 + n2)
# 5. Variance components..
cj <- hbarj / 2
aj <- (nbar / nc) * ((n1 * (p1j - pbarj)^2 - pbarj * (1 - pbarj) - hbarj / 4) + (n2 * (p2j - pbarj)^2 - pbarj * (1 - pbarj) - hbarj / 4))
bj <- nbar * (pbarj * (1 - pbarj) - cj - aj / nbar)
# 6. Fst
fst <- aj / (aj + bj + cj)
# 1. Allele freqs
n1i <- 12
n2i <- 6
n1 <- 12
n2 <- 20
p1i <- n1i/n1
p2i <- n2i/n2
# 2. Heterozygosity
Nhet1i <- 0
Nhet2i <- 4
h1i <- Nhet1i / (n1 / 2)
h2i <- Nhet2i / (n2 / 2)
hbari <- (h1i * (n1 / 2) + h2i * (n2 / 2)) / ((n1 / 2) + (n2 / 2 ))
# 3. Average allele freqs across populations
pbari <- (p1i * n1 + p2i * n2) / (n1 + n2)
# 4. Sample size corrections
nbar <- (n1 + n2) / 2
nc  <- n1 + n2 - (n1^2 + n2^2) / (n1 + n2)
# 5. Variance components..
ci <- hbari / 2
ai <- (nbar / nc) * ((n1 * (p1i - pbari)^2 - pbari * (1 - pbari) - hbari / 4) + (n2 * (p2i - pbari)^2 - pbari * (1 - pbari) - hbari / 4))
bi <- nbar * (pbari * (1 - pbari) - ci - ai / nbar)
# 6. Fst
fsti <- ai / (ai + bi + ci)
